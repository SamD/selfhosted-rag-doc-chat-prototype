# MQTT Agent Hub — Environment Configuration
# Copy to .env and adjust for your deployment.

# Broker connection (hub + edge agents use native MQTT)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_HUB_TOKEN=changeme
HUB_PORT=8100

# WebSocket listener port (Mosquitto + dashboard browser clients)
MQTT_WS_PORT=9001

# Dashboard frontend configuration (PUBLIC_ prefix = exposed to browser)
# Set PUBLIC_MQTT_BROKER_HOST when the broker is on a different host
# than the dashboard. Otherwise the dashboard uses its own hostname.
# PUBLIC_MQTT_BROKER_HOST=192.168.1.100
PUBLIC_HUB_PORT=8100
PUBLIC_MQTT_WS_PORT=9001
PUBLIC_MQTT_USERNAME=hub
PUBLIC_MQTT_PASSWORD=changeme

# Optional: enable LLM-based SRE analysis on edge agents
# LLM_PATH=/path/to/model.gguf

# Agent version reported in discovery
AGENT_VERSION=NOT_SET
