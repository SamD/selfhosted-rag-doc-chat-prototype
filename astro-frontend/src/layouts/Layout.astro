---
export interface Props {
	title: string;
}

const { title } = Astro.props;
import ThemePicker from '../components/ThemePicker.astro';
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="AI Chat Interface" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			const saved = localStorage.getItem("theme");
			if (saved) {
				document.documentElement.setAttribute("data-theme", saved);
			}
		</script>
	</head>
	<body class="min-h-screen flex flex-col">
		<header class="navbar bg-base-200 px-4 shrink-0">
			<div class="flex-1">
				<span class="text-lg font-bold">{title}</span>
			</div>
			<div class="flex-none">
				<ThemePicker />
			</div>
		</header>
		<main class="flex-1 min-h-0">
			<slot />
		</main>

		<script>
			function initThemePicker() {
				const saved = localStorage.getItem('theme');
				if (saved && !document.documentElement.getAttribute('data-theme')) {
					document.documentElement.setAttribute('data-theme', saved);
				}
				const picker = document.querySelector('select[data-choose-theme]') as HTMLSelectElement | null;
				if (picker) {
					if (saved) picker.value = saved;
					picker.addEventListener('change', () => {
						document.documentElement.setAttribute('data-theme', picker.value);
						localStorage.setItem('theme', picker.value);
					});
				}
			}
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initThemePicker);
			} else {
				initThemePicker();
			}
		</script>
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
