# Document Ingestion System Environment Variables
# Implementing a database-driven state machine architecture.

# --- PATH CONFIGURATION ---
# REQUIRED: The parent directory for all lifecycle stages
DEFAULT_DOC_INGEST_ROOT=/home/samueldoyle/Projects/GitHub/SamD/selfhosted-rag-doc-chat-prototype/Docs/TESTING

# Model Paths
EMBEDDING_MODEL_PATH=/home/samueldoyle/AI_LOCAL/e5-large-v2
LLM_PATH=/home/samueldoyle/AI_LOCAL/Models/Phi/microsoft_Phi-4-mini-instruct-Q6_K.gguf
SUPERVISOR_LLM_PATH=/home/samueldoyle/AI_LOCAL/Models/Phi/microsoft_Phi-4-mini-instruct-Q6_K.gguf
WHISPER_MODEL_PATH=/home/samueldoyle/AI_LOCAL/Models/Whisper
OCR_PATH=LOCAL

# LLM Configuration
LLAMA_REMOTE_TIMEOUT=300.0
# SUPERVISOR_REMOTE_MODEL_NAME=microsoft_Phi-4-mini-instruct-Q6_K.gguf

# State and Storage
# These now default to sub-folders of DEFAULT_DOC_INGEST_ROOT in settings.py
# PARQUET_FILE=${DEFAULT_DOC_INGEST_ROOT}/chunks.parquet
# DUCKDB_FILE=${DEFAULT_DOC_INGEST_ROOT}/chunks.duckdb
# GATEKEEPER_FAILURE_DB=${DEFAULT_DOC_INGEST_ROOT}/gatekeeper_history.db

# Redis Configuration (Unified port)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_OCR_JOB_QUEUE=ocr_processing_job
REDIS_WHISPER_JOB_QUEUE=whisper_processing_job
REDIS_INGEST_QUEUE=chunk_ingest_queue

# Queue Configuration
QUEUE_NAMES=chunk_ingest_queue:0

# Vector Database Configuration
VECTOR_DB_HOST=vector-db
VECTOR_DB_COLLECTION=vector_base_collection
# Port 9002 is exposed on host, but containers talk on internal 6333
VECTOR_DB_PORT=6333
VECTOR_DB_GRPC_PORT=6334
VECTOR_DB_USE_GRPC=true
VECTOR_DB_TIMEOUT=60.0
VECTOR_DB_BATCH_SIZE=20

# LLM and Chat Configuration
USE_OLLAMA=0
LLAMA_CHAT_FORMAT=chatml

# Media Processing Configuration
SUPPORTED_MEDIA_EXT=.mp3,.wav,.m4a,.aac,.flac,.mp4,.mov,.mkv
DEVICE=cuda
MEDIA_BATCH_SIZE=8
COMPUTE_TYPE=float16

# File Processing Configuration
CHUNK_TIMEOUT=300
MAX_CHUNKS=20000
VECTOR_DB_BATCH_SIZE=5
MAX_TOKENS=256
PDF_FORCE_OCR=false

# GPU / Inference Optimization
LLAMA_N_GPU_LAYERS=-1
LLAMA_TEMPERATURE=0.2
LLAMA_TOP_K=40
LLAMA_TOP_P=0.95
LLAMA_REPEAT_PENALTY=1.1
LLAMA_MAX_TOKENS=4096

# Metrics Configuration
METRICS_ENABLED=true
# METRICS_LOG_FILE=${DEFAULT_DOC_INGEST_ROOT}/metrics.jsonl
METRICS_LOG_TO_STDOUT=true
